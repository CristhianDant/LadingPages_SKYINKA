---
import MobileBottomBar from './MobileBottomBar.astro';

interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;

const navItems = [
  { label: 'Programas', href: '/#programas' },
  { label: 'Tándem', href: '/#tandem' },
  { label: 'Licencias Habilitaciones', href: '/#licencias' },
  { label: '', href: '', empty: true },
  { label: 'Nosotros', href: '/quienes-somos' },
  { label: 'Zonas de Salto', href: '/#zonas' },
  { label: 'Álbum', href: '/#album' },
  { label: 'Tienda', href: '/#tienda' },
  { label: 'Blog', href: '/blog' },
];
---

<header class:list={['header', className]} x-data="{ menuOpen: false }">
  <a href="/" class="header-logo-centered">
    <img src="/images/logo-header.png" alt="Skydive Inka Perú" class="logo-img" />
  </a>

  <!-- Nivel 1 - Barra Superior -->
  <div class="header-top">
    <div class="header-top-inner">
      <div class="header-social">
        <a href="https://facebook.com" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
          </svg>
        </a>
        <a href="https://x.com" target="_blank" rel="noopener noreferrer" aria-label="X">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M18.901 1.153h3.68l-8.04 9.19L24 22.846h-7.406l-5.8-7.584-6.638 7.584H.474l8.6-9.83L0 1.154h7.594l5.243 6.932ZM17.61 20.644h2.039L6.486 3.24H4.298Z"/>
          </svg>
        </a>
        <a href="https://instagram.com" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/>
          </svg>
        </a>
      </div>

      <a href="#reservar" class="btn-reserva">RESERVA</a>

      <!-- Mobile Menu Toggle -->
      <button
        class="menu-toggle"
        @click="menuOpen = !menuOpen"
        aria-label="Abrir menú"
      >
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="24" height="24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Nivel 2 - Barra de Navegación -->
  <nav class="header-nav">
    <div class="header-nav-inner">
      {
        navItems.map((item) =>
          item.empty ? (
            <span class="nav-logo-space" />
          ) : (
            <a href={item.href} class="nav-link">{item.label}</a>
          )
        )
      }
    </div>
  </nav>

  <!-- Mobile Overlay -->
  <div class="mobile-overlay" x-show="menuOpen" @click.outside="menuOpen = false" x-cloak>
    <div class="mobile-menu">
      <button class="mobile-close" @click="menuOpen = false" aria-label="Cerrar menú">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="24" height="24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
        </svg>
      </button>
      <div class="mobile-nav-items">
        {
          navItems.filter((item) => !item.empty).map((item) => (
            <a href={item.href} class="mobile-nav-link" @click="menuOpen = false">{item.label}</a>
          ))
        }
      </div>
      <div class="mobile-social">
        <a href="https://facebook.com" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
            <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
          </svg>
        </a>
        <a href="https://x.com" target="_blank" rel="noopener noreferrer" aria-label="X">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
            <path d="M18.901 1.153h3.68l-8.04 9.19L24 22.846h-7.406l-5.8-7.584-6.638 7.584H.474l8.6-9.83L0 1.154h7.594l5.243 6.932ZM17.61 20.644h2.039L6.486 3.24H4.298Z"/>
          </svg>
        </a>
        <a href="https://instagram.com" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/>
          </svg>
        </a>
      </div>
    </div>
  </div>

  <MobileBottomBar />
</header>

<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background-color: var(--bg-celeste);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
  }

  /* === Nivel 1 - Barra Superior === */
  .header-top {
    background-color: var(--bg-celeste);
    border-bottom: 1px solid var(--border-neutral);
  }

  .header-top-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: var(--container-max-width);
    margin: 0 auto;
    padding: 8px var(--container-padding-x);
    height: 56px;
  }

  .header-social {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .header-social a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--gray-text);
    transition: var(--transition);
  }

  .header-social a:hover {
    color: var(--primary-blue);
  }

  .header-logo-centered {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .logo-img {
    width: 180px;
    height: auto;
  }

  .btn-reserva {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 10px 28px;
    background-color: var(--primary-blue);
    color: var(--text-primary);
    font-family: var(--font-header);
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    border-radius: var(--border-radius);
    transition: var(--transition);
  }

  .btn-reserva:hover {
    background-color: var(--primary-dark);
  }

  /* === Nivel 2 - Barra de Navegación === */
  .header-nav {
    background-color: var(--bg-celeste);
    border-bottom: 1px solid var(--border-neutral);
  }

  .header-nav-inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 20px;
    max-width: var(--container-max-width);
    margin: 0 auto;
    padding: 0 var(--container-padding-x);
    height: 44px;
  }

  .nav-link {
    font-family: var(--font-header);
    font-size: var(--nav-size);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: var(--nav-letter-spacing);
    color: var(--gray-text);
    transition: var(--transition);
    white-space: nowrap;
    position: relative;
  }

  .nav-link:hover,
  .nav-link.active {
    color: var(--primary-blue);
  }

  .nav-logo-space {
    width: 180px;
    flex-shrink: 0;
  }

  /* === Mobile Menu Toggle === */
  .menu-toggle {
    display: none;
    position: absolute;
    right: var(--container-padding-x);
    align-items: center;
    justify-content: center;
    width: 30px;
    height: 30px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    color: var(--gray-text);
  }

  /* === Mobile Overlay === */
  .mobile-overlay {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-color: rgba(0, 0, 0, 0.6);
    z-index: 200;
  }

  .mobile-menu {
    position: absolute;
    top: 0;
    right: 0;
    width: 280px;
    height: 100%;
    background-color: var(--white);
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 24px;
    overflow-y: auto;
  }

  .mobile-close {
    align-self: flex-end;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--gray-text);
    padding: 4px;
  }

  .mobile-nav-items {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .mobile-nav-link {
    font-family: var(--font-header);
    font-size: 15px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: var(--nav-letter-spacing);
    color: var(--gray-text);
    padding: 12px 8px;
    border-radius: 4px;
    transition: var(--transition);
  }

  .mobile-nav-link:hover {
    color: var(--primary-blue);
    background-color: var(--bg-celeste);
  }

  .mobile-social {
    display: flex;
    align-items: center;
    gap: 20px;
    padding-top: 16px;
    border-top: 1px solid var(--border-neutral);
  }

  .mobile-social a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--gray-text);
    transition: var(--transition);
  }

  .mobile-social a:hover {
    color: var(--primary-blue);
  }

  /* === Responsive === */
  @media (max-width: 1024px) {
    .header-nav {
      display: none;
    }

    .menu-toggle {
      display: none;
    }

    .btn-reserva {
      display: none;
    }

    .header-social {
      display: none;
    }

  }
</style>
