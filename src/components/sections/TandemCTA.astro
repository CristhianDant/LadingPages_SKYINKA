<section class="tandem-cta">
  <img src="/images/avionalumnos.jpg" alt="Paracaidistas en formación" class="cta-bg-image" />
  <div class="cta-overlay"></div>
  <div class="cta-container container">
    <div class="cta-content">
      <h2 class="cta-title">
        Atrévete a volar
      </h2>
      <p class="cta-description">
        No mires el cielo, conquístalo. Salta, siente la adrenalina de la caída libre y descubre una experiencia que cambiará tu forma de ver la vida.
      </p>
      <div class="cta-actions">
        <a href="https://skipperu.odoo.com/shop/tdms-salto-tandem-safiro-3" class="btn-cta-primary" target="_blank" rel="noopener">
          Reservar Salto
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
        <a href="https://wa.me/51995955412" class="btn-cta-secondary" target="_blank" rel="noopener">
          Contactar por WhatsApp
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .tandem-cta {
    position: relative;
    min-height: 500px;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .cta-bg-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .cta-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      90deg,
      rgba(27, 27, 25, 0.95) 0%,
      rgba(27, 27, 25, 0.7) 50%,
      rgba(27, 27, 25, 0.4) 100%
    );
  }

  .cta-container {
    position: relative;
    z-index: 2;
    max-width: var(--container-max-width);
    margin: 0 auto;
    padding: 80px var(--container-padding-x);
    width: 100%;
  }

  .cta-content {
    max-width: 600px;
  }

  .cta-title {
    font-family: var(--font-heading);
    font-size: clamp(48px, 6vw, 72px);
    line-height: 1;
    text-transform: uppercase;
    color: var(--text-primary);
    font-weight: 400;
    margin-bottom: 24px;
  }

  .cta-description {
    font-family: var(--font-body);
    font-size: 18px;
    line-height: 1.7;
    color: var(--text-secondary);
    margin-bottom: 40px;
  }

  .cta-actions {
    display: flex;
    gap: 16px;
  }

  .btn-cta-primary {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 18px 36px;
    background-color: var(--primary-blue);
    color: var(--text-primary);
    font-family: var(--font-header);
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    transition: var(--transition);
    text-decoration: none;
  }

  .btn-cta-primary:hover {
    background-color: var(--primary-dark);
  }

  .btn-cta-primary:hover svg {
    transform: translateX(4px);
  }

  .btn-cta-primary svg {
    transition: transform 0.3s ease;
  }

  .btn-cta-secondary {
    display: inline-flex;
    align-items: center;
    padding: 18px 36px;
    background-color: transparent;
    color: var(--text-primary);
    font-family: var(--font-header);
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    border: 2px solid var(--text-primary);
    transition: var(--transition);
    text-decoration: none;
  }

  .btn-cta-secondary:hover {
    background-color: var(--text-primary);
    color: var(--bg-dark);
  }

  @media (max-width: 768px) {
    .tandem-cta {
      min-height: 400px;
    }

    .cta-container {
      padding: 60px var(--container-padding-x);
    }

    .cta-actions {
      flex-direction: column;
    }

    .btn-cta-primary,
    .btn-cta-secondary {
      width: 100%;
      justify-content: center;
    }
  }
</style>
