const fileTextIcon = '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 22a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h8a2.4 2.4 0 0 1 1.704.706l3.588 3.588A2.4 2.4 0 0 1 20 8v12a2 2 0 0 1-2 2z"/><path d="M14 2v5a1 1 0 0 0 1 1h5"/><path d="M10 9H8"/><path d="M16 13H8"/><path d="M16 17H8"/></svg>';
const cameraIcon = '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13.997 4a2 2 0 0 1 1.76 1.05l.486.9A2 2 0 0 0 18.003 7H20a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V9a2 2 0 0 1 2-2h1.997a2 2 0 0 0 1.759-1.048l.489-.904A2 2 0 0 1 10.004 4z"/><circle cx="12" cy="13" r="3"/></svg>';
const shieldCheckIcon = '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/><path d="m9 12 2 2 4-4"/></svg>';
const creditCardIcon = '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="14" x="2" y="5" rx="2"/><line x1="2" x2="22" y1="10" y2="10"/></svg>';

const terms = [
  {
    title: 'Servicios Adicionales No Incluidos',
    icon: packageXIcon,
    items: [
      'Transporte a Paracas, alojamiento y alimentación'
    ]
  },
  {
    title: 'Instrucciones Específicas',
    icon: mapPinIcon,
    items: [
      'Punto de encuentro: Hotel "El Zarcillo", en Paracas',
      'Hora de presentación: 05:00 A.M.',
      'Si no te presentas el día del salto, perderás el 100% de tu inversión',
      'Reprogramaciones deben solicitarse con un mínimo de 72 horas de anticipación',
      'La actividad se realiza según el orden de llegada',
      'Tiempo de espera estimado entre un vuelo y el siguiente es de 2 horas',
      'Condiciones Meteorológicas No Favorables pueden causar suspensión o reprogramación',
      'Entrega de copia del video de obsequio en 5 días hábiles después del salto'
    ]
  },
  {
    title: 'Vestimenta y Alimentación',
    icon: shirtIcon,
    items: [
      'Ropa deportiva, sin objetos de valor, bloqueador',
      'Prohibido el uso de aretes, anillos, cadenas, prendas metálicas',
      'Consumir alimentos ligeros, nutritivos e hidratantes',
      'No consumir lácteos antes del salto'
    ]
  },
  {
    title: 'Formularios y Documentación',
    icon: fileTextIcon,
    items: [
      'Llenar los formularios virtuales sobre declaración jurada de buena salud y waiver',
      'Si no está de acuerdo con algún punto, desista de saltar'
    ]
  },
  {
    title: 'Políticas de Imágenes y Derechos',
    icon: cameraIcon,
    items: [
      'SKYDIVE INKA PERÚ es propietario de las fotografías y videos generados durante el embarque, vuelo y lanzamiento',
      'Nos reservamos el derecho de emplearlos para promoción y difusión del Paracaidismo',
      'Nos reservamos el derecho de admisión ante indisciplina Aerodeportiva'
    ]
  },
  {
    title: 'Responsabilidad',
    icon: shieldCheckIcon,
    items: [
      'Cualquier imprecisión respecto del estado de salud física y mental es exclusivamente responsable de cualquier incidente',
      'Cualquier duda, consulte con un profesional especialista'
    ]
  },
  {
    title: 'Métodos de Pago',
    icon: creditCardIcon,
    items: [
      'Transferencia bancaria (sin recargo)',
      'Tarjeta de crédito o débito (link de pago con recargo del 5%)',
      'Pago en efectivo el día del salto (sin reserva, sujeto a disponibilidad)',
      'Prioridad para quienes tengan reserva confirmada'
    ]
  }
];
---

<section id="terminos" class="tandem-terms">
  <div class="terms-container container">
    <div class="terms-header">
      <span class="terms-tag">Términos y Condiciones</span>
      <h2 class="terms-title">
        Importante saber<br />
        <span class="terms-accent">antes de saltar</span>
      </h2>
    </div>
    <div class="terms-tabs" x-data="{ activeTab: 0 }">
      <div class="tabs-bar">
        {terms.map((section, index) => (
          <button
            class="tab-btn"
            :class="{ 'active': activeTab === index }"
            @click={`activeTab = ${index}`}
          >
            <span class="tab-icon" set:html={section.icon} />
            <span class="tab-label">{section.title}</span>
          </button>
        ))}
      </div>
      <div class="tab-panels">
        {terms.map((section, index) => (
          <div class="terms-card" x-show={`activeTab === ${index}`} x-transition:enter.duration.200ms>
            <h3 class="card-title">{section.title}</h3>
            <ul class="card-list">
              {section.items.map((item) => (
                <li class="card-item">{item}</li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
    <div class="terms-steps">
      <h3 class="steps-title">Pasos para Reservar tu Salto</h3>
      <div class="steps-grid">
        <div class="step-item">
          <span class="step-number">01</span>
          <p class="step-text">Realiza la transferencia bancaria o solicita el enlace de pago con tarjeta de crédito o débito (recargo del 5%).</p>
        </div>
        <div class="step-item">
          <span class="step-number">02</span>
          <p class="step-text">Llenar y enviar el formulario virtual de declaración jurada de buen estado de salud, manifiesto de vuelo y waiver.</p>
        </div>
        <div class="step-item">
          <span class="step-number">03</span>
          <p class="step-text">Menores de edad (16 años cumplidos) deben presentar permiso notarial y estar acompañados por el padre o la madre.</p>
        </div>
      </div>
    </div>
    <div class="terms-important">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
        <line x1="12" y1="9" x2="12" y2="13"/>
        <line x1="12" y1="17" x2="12.01" y2="17"/>
      </svg>
      <p class="important-text">
        <strong>IMPORTANTE:</strong> Las operaciones pueden suspenderse y/o reprogramarse. No realizamos reembolsos de ningún tipo.
      </p>
    </div>
  </div>
</section>

<style>
  .tandem-terms {
    background-color: var(--white);
    padding: var(--section-padding) 0;
  }

  .terms-container {
    max-width: var(--container-max-width);
    margin: 0 auto;
    padding: 0 var(--container-padding-x);
  }

  .terms-header {
    text-align: center;
    margin-bottom: 64px;
  }

  .terms-tag {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 3px;
    color: var(--primary-blue);
    margin-bottom: 20px;
    position: relative;
    padding: 0 40px;
  }

  .terms-tag::before,
  .terms-tag::after {
    content: '';
    position: absolute;
    top: 50%;
    width: 28px;
    height: 2px;
    background-color: var(--primary-blue);
  }

  .terms-tag::before {
    left: 0;
  }

  .terms-tag::after {
    right: 0;
  }

  .terms-title {
    font-family: var(--font-heading);
    font-size: clamp(32px, 4vw, 48px);
    line-height: 1;
    text-transform: uppercase;
    color: var(--text-dark);
    font-weight: 400;
  }

  .terms-accent {
    color: var(--primary-blue);
  }

  .terms-tabs {
    margin-bottom: 64px;
  }

  .tabs-bar {
    display: flex;
    gap: 8px;
    overflow-x: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
    margin-bottom: 32px;
    padding-bottom: 4px;
  }

  .tabs-bar::-webkit-scrollbar {
    display: none;
  }

  .tab-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 18px;
    background: none;
    border: 2px solid var(--gray-light);
    border-radius: 0;
    font-family: var(--font-header);
    font-size: 12px;
    font-weight: 600;
    color: var(--gray-medium);
    white-space: nowrap;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    transition: var(--transition);
    cursor: pointer;
    flex-shrink: 0;
  }

  .tab-btn:hover {
    border-color: var(--primary-blue);
    color: var(--primary-blue);
  }

  .tab-btn.active {
    background-color: var(--primary-blue);
    border-color: var(--primary-blue);
    color: var(--text-primary);
  }

  .tab-icon {
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }

  .tab-icon :global(svg) {
    width: 18px;
    height: 18px;
  }

  .tab-panels {
    position: relative;
  }

  .terms-card {
    padding: 40px;
    background-color: var(--bg-celeste);
    border-left: 4px solid var(--primary-blue);
  }

  .card-title {
    font-family: var(--font-header);
    font-size: 20px;
    font-weight: 700;
    color: var(--text-dark);
    margin-bottom: 24px;
    padding-bottom: 16px;
    border-bottom: 2px solid var(--primary-blue);
  }

  .card-list {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .card-item {
    font-family: var(--font-body);
    font-size: 15px;
    line-height: 1.7;
    color: var(--gray-text);
    padding-left: 24px;
    position: relative;
  }

  .card-item::before {
    content: '';
    position: absolute;
    left: 0;
    top: 10px;
    width: 6px;
    height: 6px;
    background-color: var(--primary-blue);
    border-radius: 50%;
  }

  .terms-steps {
    margin-bottom: 48px;
  }

  .steps-title {
    font-family: var(--font-heading);
    font-size: 32px;
    text-transform: uppercase;
    color: var(--text-dark);
    font-weight: 400;
    margin-bottom: 32px;
    text-align: center;
  }

  .steps-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .step-item {
    padding: 32px;
    background-color: var(--bg-dark);
    position: relative;
  }

  .step-number {
    display: block;
    font-family: var(--font-heading);
    font-size: 48px;
    color: var(--primary-blue);
    opacity: 0.3;
    margin-bottom: 16px;
    line-height: 1;
  }

  .step-text {
    font-family: var(--font-body);
    font-size: 14px;
    line-height: 1.7;
    color: var(--text-secondary);
  }

  .terms-important {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    padding: 32px;
    background-color: rgba(204, 51, 102, 0.1);
    border-left: 4px solid var(--pink-accent);
  }

  .terms-important svg {
    color: var(--pink-accent);
    flex-shrink: 0;
  }

  .important-text {
    font-family: var(--font-body);
    font-size: 14px;
    line-height: 1.7;
    color: var(--text-dark);
  }

  .important-text strong {
    color: var(--pink-accent);
  }

  @media (max-width: 1024px) {
    .steps-grid {
      grid-template-columns: 1fr;
    }

    .tabs-bar {
      flex-wrap: wrap;
      overflow-x: visible;
    }
  }

  @media (max-width: 768px) {
    .tandem-terms {
      padding: 48px 0;
    }

    .tabs-bar {
      gap: 6px;
      margin-bottom: 24px;
    }

    .tab-btn {
      padding: 8px 14px;
      font-size: 11px;
    }

    .tab-icon :global(svg) {
      width: 16px;
      height: 16px;
    }

    .terms-card {
      padding: 24px;
    }

    .card-title {
      font-size: 18px;
      margin-bottom: 20px;
      padding-bottom: 12px;
    }

    .card-item {
      font-size: 14px;
      padding-left: 20px;
    }

    .card-item::before {
      top: 8px;
      width: 5px;
      height: 5px;
    }

    .step-item {
      padding: 24px;
    }
  }
</style>
