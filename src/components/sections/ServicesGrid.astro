---
const services = [
  {
    title: 'Salto Tándem',
    description: 'La experiencia de paracaidismo más popular. Salta con un instructor certificado y disfruta de vistas increíbles.',
    price: 'S/. 2,199',
    image: '/images/AFF.webp',
    link: '/salto-tandem',
    column: 1
  },
  {
    title: 'Escuela de Paracaidismo',
    description: 'Conviértete en paracaidista certificado con nuestro programa de formación completo.',
    price: 'S/. 10,000',
    image: '/images/APERTURA.webp',
    link: '#escuelas',
    column: 2
  },
  {
    title: 'Vuelo en Girocóptero',
    description: 'Disfruta de una experiencia única volando en girocóptero sobre la costa de Pisco.',
    price: 'S/. 1,099',
    image: '/images/avionalumnos.jpg',
    link: '#vuelos',
    column: 1
  }
];

const column1 = services.filter(s => s.column === 1);
const column2 = services.filter(s => s.column === 2);
---

<section id="servicios" class="services-section">
  <div class="container">
    <h2 class="h2 text-primary services-title">Nuestros Servicios</h2>
    <div class="services-columns">
      <div class="service-column">
        {column1.map((service) => (
          <article class="service-card">
            <div class="service-image-wrapper">
              <img src={service.image} alt={service.title} class="service-image" />
              <div class="service-overlay"></div>
              <h3 class="h3 service-title">{service.title}</h3>
            </div>
            <div class="service-content">
              <p class="service-price">{service.price}</p>
              <p class="service-desc">{service.description}</p>
              <a href={service.link} class="service-link">Saber Más →</a>
            </div>
          </article>
        ))}
      </div>
      <div class="service-column service-column--offset">
        {column2.map((service) => (
          <article class="service-card">
            <div class="service-image-wrapper">
              <img src={service.image} alt={service.title} class="service-image" />
              <div class="service-overlay"></div>
              <h3 class="h3 service-title">{service.title}</h3>
            </div>
            <div class="service-content">
              <p class="service-price">{service.price}</p>
              <p class="service-desc">{service.description}</p>
              <a href={service.link} class="service-link">Saber Más →</a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .services-section {
    background-color: var(--bg-dark);
    padding: var(--section-padding) 0;
  }

  .services-title {
    text-align: center;
    margin-bottom: 64px;
  }

  .services-columns {
    display: flex;
    gap: var(--grid-gap);
  }

  .service-column {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--grid-gap);
  }

  .service-column--offset {
    margin-top: 120px;
  }

  .service-card {
    position: relative;
    overflow: hidden;
    height: 420px;
    background-color: var(--bg-dark);
    transition: var(--transition);
  }

  .service-image-wrapper {
    position: relative;
    height: 100%;
    overflow: hidden;
  }

  .service-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .service-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(0, 0, 0, 0.4) 0%,
      rgba(0, 0, 0, 0) 40%,
      rgba(0, 0, 0, 0) 60%,
      rgba(0, 0, 0, 0.4) 100%
    );
  }

  .service-title {
    position: absolute;
    top: 24px;
    left: 50%;
    transform: translateX(-50%);
    text-align: center;
    color: var(--text-primary);
    z-index: 2;
    width: 100%;
    padding: 0 24px;
  }

  .service-content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background-color: var(--bg-dark);
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    transform: translateY(100%);
    transition: transform 0.4s ease;
  }

  .service-card:hover .service-content {
    transform: translateY(0);
  }

  .service-price {
    font-family: var(--font-header);
    font-size: 24px;
    font-weight: 700;
    color: var(--text-primary);
  }

  .service-desc {
    font-size: 14px;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  .service-link {
    display: inline-flex;
    align-items: center;
    padding: 12px 24px;
    background-color: var(--pink-accent);
    color: var(--text-primary);
    font-family: var(--font-header);
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    border-radius: var(--border-radius);
    transition: var(--transition);
    width: fit-content;
  }

  .service-link:hover {
    opacity: 0.9;
  }

  @media (max-width: 768px) {
    .services-columns {
      flex-direction: column;
    }

    .service-column--offset {
      margin-top: 0;
    }

    .service-card {
      height: 300px;
    }

    .service-content {
      transform: translateY(0);
    }
  }
</style>
