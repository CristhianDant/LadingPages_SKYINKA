---
---

<div class="hero-left">
  <img src="/images/AFF.webp" alt="Programa Regular de Caída Libre PRECAL" class="hero-image" />
  <div class="hero-overlay"></div>
  <div class="hero-content-left">
    <span class="hero-tag">Programa de Formación</span>
    <h1 class="hero-title">Programa<br />Regular de<br />Caída Libre</h1>
    <p class="hero-subtitle">PRECAL</p>
    <div class="hero-price-block">
      <span class="price-label">Curso completo</span>
      <span class="price-value">S/. 1,970 <span class="price-igv">+ IGV</span></span>
    </div>
    <div class="hero-buttons">
      <a href="#reservar" class="btn-reservar">
        Reservar Vacante
      </a>
      <a href="#fases" class="btn-explorar">
        Ver Programa
      </a>
    </div>
  </div>
</div>

<style>
  .hero-left {
    position: relative;
    overflow: hidden;
    height: 100%;
  }

  .hero-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(0, 0, 0, 0.25) 0%,
      rgba(0, 0, 0, 0.45) 40%,
      rgba(0, 0, 0, 0.75) 100%
    );
  }

  .hero-content-left {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 60px;
    z-index: 2;
  }

  .hero-tag {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 3px;
    color: var(--primary-light);
    margin-bottom: 20px;
  }

  .hero-title {
    font-family: var(--font-heading);
    font-size: clamp(40px, 5vw, 64px);
    line-height: 0.95;
    text-transform: uppercase;
    color: var(--text-primary);
    font-weight: 400;
    margin-bottom: 12px;
  }

  .hero-subtitle {
    font-family: var(--font-header);
    font-size: 14px;
    font-weight: 700;
    color: var(--accent-gold);
    text-transform: uppercase;
    letter-spacing: 5px;
    margin-bottom: 32px;
  }

  .hero-price-block {
    display: flex;
    flex-direction: column;
    gap: 4px;
    margin-bottom: 32px;
  }

  .price-label {
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .price-value {
    font-family: var(--font-heading);
    font-size: 48px;
    color: var(--text-primary);
    line-height: 1;
  }

  .price-igv {
    font-size: 24px;
    color: var(--text-secondary);
  }

  .hero-buttons {
    display: flex;
    gap: 16px;
  }

  .btn-reservar {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 16px 32px;
    background-color: var(--primary-blue);
    color: var(--text-primary);
    font-family: var(--font-header);
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    transition: var(--transition);
    text-decoration: none;
  }

  .btn-reservar:hover {
    background-color: var(--primary-dark);
  }

  .btn-explorar {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 16px 32px;
    background-color: transparent;
    color: var(--text-primary);
    font-family: var(--font-header);
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    border: 2px solid var(--text-primary);
    transition: var(--transition);
    text-decoration: none;
  }

  .btn-explorar:hover {
    background-color: var(--text-primary);
    color: var(--bg-dark);
  }

  @media (max-width: 1024px) {
    .hero-left {
      height: 70vh;
      min-height: 600px;
    }

    .hero-content-left {
      padding: 40px;
    }
  }

  @media (max-width: 768px) {
    .hero-left {
      height: 60vh;
      min-height: 500px;
    }

    .hero-content-left {
      padding: 30px;
    }

    .hero-title {
      font-size: 36px;
    }

    .price-value {
      font-size: 36px;
    }

    .hero-buttons {
      flex-direction: column;
    }
  }
</style>
