<style>
  .tandem-pricing {
    background-color: var(--bg-celeste);
    padding: var(--section-padding) 0;
  }

  .pricing-container {
    max-width: var(--container-max-width);
    margin: 0 auto;
    padding: 0 var(--container-padding-x);
    display: flex;
    justify-content: center;
  }

  .pricing-card {
    max-width: 900px;
    width: 100%;
    background-color: var(--white);
    display: grid;
    grid-template-columns: 1fr 1fr;
    overflow: hidden;
  }

  .pricing-header {
    padding: 60px;
    background-color: var(--bg-dark);
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .pricing-tag {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 3px;
    color: var(--primary-light);
    margin-bottom: 24px;
  }

  .pricing-altitude {
    margin-bottom: 32px;
  }

  .altitude-number {
    font-family: var(--font-heading);
    font-size: 72px;
    color: var(--text-primary);
    line-height: 1;
  }

  .altitude-unit {
    font-family: var(--font-body);
    font-size: 18px;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 2px;
    margin-left: 8px;
  }

  .pricing-description {
    font-family: var(--font-body);
    font-size: 14px;
    line-height: 1.7;
    color: var(--text-secondary);
    margin-bottom: 16px;
  }

  .pricing-cta-text {
    font-family: var(--font-body);
    font-size: 14px;
    line-height: 1.7;
    color: var(--text-primary);
    margin-top: 8px;
  }

  .pricing-cta-text strong {
    color: var(--primary-light);
  }

  .pricing-body {
    padding: 60px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .pricing-price-block {
    margin-bottom: 32px;
  }

  .price-label {
    display: block;
    font-family: var(--font-body);
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--gray-medium);
    margin-bottom: 8px;
  }

  .price-value {
    display: flex;
    align-items: baseline;
    gap: 8px;
  }

  .currency {
    font-family: var(--font-body);
    font-size: 24px;
    color: var(--text-dark);
  }

  .amount {
    font-family: var(--font-heading);
    font-size: 64px;
    color: var(--text-dark);
    line-height: 1;
  }

  .igv {
    font-family: var(--font-body);
    font-size: 18px;
    color: var(--gray-medium);
  }

  .pricing-actions {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 32px;
  }

  .btn-reservar-pricing {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 18px 36px;
    background-color: var(--primary-blue);
    color: var(--text-primary);
    font-family: var(--font-header);
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    transition: var(--transition);
    text-decoration: none;
  }

  .btn-reservar-pricing:hover {
    background-color: var(--primary-dark);
  }

  .btn-whatsapp-pricing {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 18px 36px;
    background-color: var(--whatsapp-green);
    color: var(--text-primary);
    font-family: var(--font-header);
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    transition: var(--transition);
    text-decoration: none;
  }

  .btn-whatsapp-pricing:hover {
    background-color: #1da851;
  }

  .pricing-info {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding-top: 24px;
    border-top: 1px solid var(--gray-light);
  }

  .info-item {
    display: flex;
    align-items: center;
    gap: 12px;
    font-family: var(--font-body);
    font-size: 13px;
    color: var(--gray-text);
  }

  .info-item svg {
    color: var(--primary-blue);
    flex-shrink: 0;
  }

  @media (max-width: 1024px) {
    .pricing-card {
      grid-template-columns: 1fr;
    }

    .pricing-header,
    .pricing-body {
      padding: 40px;
    }
  }

  @media (max-width: 768px) {
    .tandem-pricing {
      padding: 48px 0;
    }

    .pricing-header,
    .pricing-body {
      padding: 32px 24px;
    }

    .altitude-number {
      font-size: 56px;
    }

    .amount {
      font-size: 48px;
    }

    .pricing-actions {
      gap: 12px;
    }
  }
</style>
