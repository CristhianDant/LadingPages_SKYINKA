---
const rawPhases = [
  {
    number: '01',
    title: 'FASE I — CLASE TEÓRICA',
    location: 'Lima',
    description: 'Esta Fase se desarrolla en la ciudad de Lima, realizamos clases teóricas presenciales (100% gratuitas), entre 6 a 8 horas académicas y se imparten en nuestras instalaciones, por lo general los sábados o lunes de 2pm a 10 pm. Corresponde a esta fase realizar el trámite de la licencia en forma personal o a través de un representante legal (aspecto relevante para los paracaidistas que proceden de provincia).',
    icon: '📚'
  },
  {
    number: '02',
    title: 'FASE II — RECONOCIMIENTO Y ENTRENAMIENTO',
    location: 'Paracas',
    description: 'Esta Fase se desarrolla en Paracas, 100% presencial. Realizamos reconocimiento de Zona de Salto, simulación de procedimientos en la aeronave y emergencias en módulos a escala y reentrenamiento de 9am a 7 pm ADRENARENA, Km. 253 Panamericana Sur – Hotel El Zarcillo en Paracas.',
    icon: '🎯'
  },
  {
    number: '03',
    title: 'FASE III — PRIMER SALTO',
    location: 'Paracas',
    description: 'Esta Fase se desarrolla en Paracas, 100% presencial, realizaremos tu primer salto.',
    icon: '✈️'
  },
  {
    number: '04',
    title: 'FASE IV — PROGRESIÓN DE SEGURIDAD',
    location: 'Paracas',
    description: 'Luego de tu primer salto, deberás de realizar en forma progresiva 34 saltos para el cambio de la licencia de alumno paracaidista por Paracaidista A Novel.',
    icon: '🪂'
  }
];

const phases = rawPhases.map((p, i) => ({
  ...p,
  label: p.title.split('—')[1]?.trim() || p.title,
  activeBtnClass: `{ 'is-active': openIndex === ${i} }`,
  expandedClass: `{ 'is-expanded': openIndex === ${i} }`,
  rotatedClass: `{ 'rotated': openIndex === ${i} }`,
  showExpr: `openIndex === ${i}`,
  toggleExpr: `openIndex = ${i}`,
}));
---

<section id="fases" class="phases-section" x-data="{ openIndex: 0 }">
  <div class="phases-container">
    <div class="phases-header">
      <span class="phases-tag">Programa PRECAL</span>
      <h2 class="phases-title">Cuatro Fases Estratégicas</h2>
      <p class="phases-subtitle">
        Un programa estructurado en 4 fases que te llevará desde la teoría hasta tu primer salto en caída libre y más allá.
      </p>
    </div>

    <div class="progress-bar" id="precal-progress">
      <div class="progress-track">
        <div class="progress-fill" id="precal-progress-fill"></div>
      </div>
      <div class="progress-steps">
        {phases.map((phase, index) => (
          <div class="progress-step" data-phase={index}>
            <button
              class="progress-step-btn"
              :class={phase.activeBtnClass}
              @click={phase.toggleExpr}
            >
              <span class="step-number">{phase.number}</span>
              <span class="step-icon">{phase.icon}</span>
            </button>
            <span class="step-label">{phase.label}</span>
          </div>
        ))}
      </div>
    </div>

    <div class="phases-accordion">
      {phases.map((phase) => (
        <div class="phase-card">
          <button
            class="phase-header"
            :class={phase.expandedClass}
            @click={phase.toggleExpr}
          >
            <div class="phase-header-left">
              <span class="phase-number">{phase.number}</span>
              <div class="phase-header-info">
                <h3 class="phase-title">{phase.title}</h3>
                <span class="phase-location">{phase.location} &middot; {phase.icon}</span>
              </div>
            </div>
            <svg
              class="phase-chevron"
              :class={phase.rotatedClass}
              width="24" height="24" viewBox="0 0 24 24" fill="none"
              stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
            >
              <polyline points="6 9 12 15 18 9"/>
            </svg>
          </button>
          <div
            class="phase-body"
            x-show={phase.showExpr}
            x-collapse.duration.200ms
          >
            <div class="phase-body-inner">
              <p class="phase-description">{phase.description}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const index = parseInt(entry.target.dataset.phase);
        const fill = document.getElementById('precal-progress-fill');
        const pct = ((index + 1) / 4) * 100;
        fill.style.width = `${pct}%`;
        entry.target.classList.add('is-visible');
      }
    });
  }, { threshold: 0.5 });

  document.querySelectorAll('.progress-step').forEach(step => observer.observe(step));
</script>

<style>
  .phases-section {
    background-color: var(--bg-dark);
  }

  .phases-container {
    padding: 80px 40px 64px;
    max-width: 720px;
    margin: 0 auto;
  }

  .phases-header {
    margin-bottom: 48px;
  }

  .phases-tag {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 3px;
    color: var(--primary-blue);
    margin-bottom: 16px;
  }

  .phases-title {
    font-family: var(--font-heading);
    font-size: clamp(32px, 4vw, 42px);
    line-height: 1;
    text-transform: uppercase;
    color: var(--text-primary);
    font-weight: 400;
    margin-bottom: 12px;
  }

  .phases-subtitle {
    font-family: var(--font-body);
    font-size: 14px;
    line-height: 1.6;
    color: var(--text-secondary);
  }

  /* ===== PROGRESS BAR ===== */
  .progress-bar {
    margin-bottom: 48px;
  }

  .progress-track {
    height: 3px;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 2px;
    margin-bottom: 20px;
    position: relative;
  }

  .progress-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--primary-blue), var(--accent-gold));
    border-radius: 2px;
    width: 0%;
    transition: width 0.6s cubic-bezier(0.22, 0.61, 0.36, 1);
  }

  .progress-steps {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
  }

  .progress-step {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    opacity: 0.35;
    transition: opacity 0.4s ease;
  }

  .progress-step.is-visible {
    opacity: 1;
  }

  .progress-step-btn {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    border: 2px solid rgba(255, 255, 255, 0.15);
    background: var(--bg-dark);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1px;
    cursor: pointer;
    transition: all 0.3s ease;
    padding: 0;
  }

  .progress-step-btn.is-active,
  .progress-step-btn:hover {
    border-color: var(--primary-blue);
    background: rgba(77, 124, 234, 0.15);
    box-shadow: 0 0 20px rgba(77, 124, 234, 0.2);
  }

  .step-number {
    font-family: var(--font-header);
    font-size: 13px;
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1;
  }

  .step-icon {
    font-size: 14px;
    line-height: 1;
  }

  .step-label {
    font-family: var(--font-body);
    font-size: 9px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--text-secondary);
    text-align: center;
    max-width: 80px;
    line-height: 1.2;
  }

  /* ===== ACCORDION ===== */
  .phases-accordion {
    display: flex;
    flex-direction: column;
    gap: 1px;
  }

  .phase-card {
    border: 1px solid rgba(255, 255, 255, 0.06);
  }

  .phase-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: 20px 24px;
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
    transition: background 0.3s ease;
  }

  .phase-header:hover {
    background: rgba(255, 255, 255, 0.03);
  }

  .phase-header.is-expanded {
    background: rgba(77, 124, 234, 0.06);
  }

  .phase-header-left {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .phase-number {
    font-family: var(--font-heading);
    font-size: 28px;
    color: var(--primary-blue);
    opacity: 0.4;
    line-height: 1;
    min-width: 36px;
  }

  .phase-header.is-expanded .phase-number {
    opacity: 1;
  }

  .phase-header-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .phase-title {
    font-family: var(--font-header);
    font-size: 13px;
    font-weight: 700;
    color: var(--text-primary);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    line-height: 1.3;
  }

  .phase-header.is-expanded .phase-title {
    color: var(--primary-light);
  }

  .phase-location {
    font-family: var(--font-body);
    font-size: 11px;
    color: var(--text-secondary);
  }

  .phase-chevron {
    flex-shrink: 0;
    color: var(--text-secondary);
    transition: transform 0.3s cubic-bezier(0.22, 0.61, 0.36, 1);
  }

  .phase-chevron.rotated {
    transform: rotate(180deg);
    color: var(--primary-blue);
  }

  .phase-body {
    overflow: hidden;
  }

  .phase-body-inner {
    padding: 0 24px 24px 76px;
  }

  .phase-description {
    font-family: var(--font-body);
    font-size: 13px;
    line-height: 1.75;
    color: var(--text-secondary);
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 768px) {
    .phases-container {
      padding: 48px 20px 40px;
    }

    .progress-step-btn {
      width: 40px;
      height: 40px;
    }

    .step-number {
      font-size: 11px;
    }

    .step-icon {
      font-size: 12px;
    }

    .step-label {
      font-size: 8px;
      max-width: 60px;
    }

    .phase-header {
      padding: 16px;
    }

    .phase-body-inner {
      padding: 0 16px 20px 52px;
    }

    .phase-number {
      font-size: 24px;
      min-width: 28px;
    }
  }
</style>
