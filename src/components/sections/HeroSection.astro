---
---

<section class="hero-section">
  <iframe 
    class="hero-video" 
    src="https://drive.google.com/file/d/13ZUVd-oAj-eO05-qnUBu3zZBZrnLM1un/preview" 
    allow="autoplay; encrypted-media" 
    allowfullscreen
    frameborder="0"
  ></iframe>
  <div class="hero-overlay"></div>
  <div class="hero-content container">
    <h1 class="h1-hero text-primary">
      Descubre la aventura de paracaidismo más buscada del mundo y vive una experiencia elevada
    </h1>
  </div>
</section>

<style>
  .hero-section {
    position: relative;
    width: 100%;
    height: 100vh;
    min-height: 889px;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
  }

  .hero-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    border: none;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(0, 0, 0, 0) 0%,
      rgba(0, 0, 0, 0.4) 40%,
      rgba(0, 0, 0, 1) 100%
    );
    z-index: 1;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    padding-bottom: 120px;
    max-width: 900px;
  }

  @media (max-width: 768px) {
    .hero-section {
      min-height: 600px;
    }

    .hero-content {
      padding-bottom: 80px;
    }
  }
</style>
