---

<section class="tandem-hero">
  <div class="hero-bg"></div>
  <div class="hero-overlay"></div>
  <div class="hero-content container">
    <h1 class="h1-hero text-primary hero-title">
      Salto<br />Tándem
    </h1>
    <p class="hero-price">S/. 2,199</p>
    <div class="hero-buttons">
      <a href="#reservar" class="btn-primary">Reservar Ahora</a>
      <a href="#vale" class="btn-outline">Vale de Regalo</a>
    </div>
  </div>
</section>

<style>
  .tandem-hero {
    position: relative;
    width: 100%;
    height: 600px;
    display: flex;
    align-items: flex-start;
    overflow: hidden;
    margin-top: 84px;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background-color: #1a1a2e;
    background-image: url('/images/AFF.webp');
    background-size: cover;
    background-position: center;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      90deg,
      rgba(0, 0, 0, 0.8) 0%,
      rgba(0, 0, 0, 0) 100%
    );
  }

  .hero-content {
    position: relative;
    z-index: 2;
    padding-top: 120px;
    max-width: 500px;
  }

  .hero-title {
    font-size: 72px;
    line-height: 1;
    margin-bottom: 16px;
  }

  .hero-price {
    font-family: var(--font-body);
    font-size: 24px;
    font-weight: 600;
    color: var(--primary-blue);
    margin-bottom: 24px;
  }

  .hero-buttons {
    display: flex;
    gap: 16px;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 14px 28px;
    background-color: var(--primary-blue);
    color: var(--text-primary);
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 600;
    text-transform: uppercase;
    border-radius: var(--border-radius);
    transition: var(--transition);
    text-decoration: none;
  }

  .btn-primary:hover {
    background-color: var(--primary-dark);
  }

  .btn-outline {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 14px 28px;
    background-color: transparent;
    color: var(--text-primary);
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 600;
    text-transform: uppercase;
    border: 1px solid var(--text-primary);
    border-radius: var(--border-radius);
    transition: var(--transition);
    text-decoration: none;
  }

  .btn-outline:hover {
    background-color: var(--text-primary);
    color: var(--bg-dark);
  }

  @media (max-width: 768px) {
    .tandem-hero {
      height: 500px;
    }

    .hero-title {
      font-size: 56px;
    }

    .hero-buttons {
      flex-direction: column;
    }
  }
</style>
