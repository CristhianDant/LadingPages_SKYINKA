---
interface Props {}
---

<div class="mobile-bottom-bar">
  <a href="#reservar" class="bb-action bb-reserva">RESERVA</a>

  <a href="tel:+51999999999" class="bb-action bb-call">
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
      <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
    </svg>
    Call
  </a>

  <button class="bb-action bb-menu" onclick="document.querySelector('[x-data]').__x.$data.menuOpen = true">
    Menu
  </button>

  <button class="bb-action bb-top" onclick="window.scrollTo({top: 0, behavior: 'smooth'})">
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M18 15l-6-6-6 6"/>
    </svg>
  </button>
</div>

<style>
  .mobile-bottom-bar {
    display: none;
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background-color: var(--bg-dark);
    padding: 8px 16px;
    padding-bottom: calc(8px + env(safe-area-inset-bottom, 0px));
    justify-content: space-between;
    align-items: center;
  }

  .bb-action {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    font-family: var(--font-header);
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--white);
    text-decoration: none;
    border: none;
    cursor: pointer;
    background: none;
    padding: 8px 12px;
    transition: var(--transition);
  }

  .bb-reserva {
    background-color: var(--primary-blue);
    border-radius: var(--border-radius);
    padding: 10px 16px;
  }

  .bb-reserva:hover {
    background-color: var(--primary-dark);
  }

  .bb-call {
    gap: 6px;
  }

  .bb-call:hover {
    color: var(--primary-light);
  }

  .bb-menu:hover {
    color: var(--primary-light);
  }

  .bb-top {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background-color: rgba(255, 255, 255, 0.15);
    padding: 0;
  }

  .bb-top:hover {
    background-color: rgba(255, 255, 255, 0.25);
  }

  @media (max-width: 1024px) {
    .mobile-bottom-bar {
      display: flex;
    }
  }
</style>
