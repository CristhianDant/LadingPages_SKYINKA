---
---

<section class="precal-cta">
  <div class="cta-bg-pattern" aria-hidden="true"></div>
  <div class="cta-container">
    <div class="cta-content">
      <img src="/images/isotipo-skip.svg" alt="" class="cta-isotipo" aria-hidden="true" />
      <h2 class="cta-title">
        ¿Quieres ser<br />
        <span class="cta-accent">paracaidista?</span>
      </h2>
      <div class="cta-motto">
        <span class="motto-word">Atrévete</span>
        <span class="motto-separator">—</span>
        <span class="motto-word">Vive</span>
        <span class="motto-separator">—</span>
        <span class="motto-word">Vuela</span>
      </div>
      <p class="cta-desc">
        Únete a nuestra comunidad aerodeportiva. Forma parte de Skydive Inka Perú
        y conviértete en un paracaidista certificado con el respaldo de instructores
        de nivel internacional.
      </p>
      <div class="cta-actions">
        <a href="https://skipperu.odoo.com/precal" class="cta-btn-primary" target="_blank" rel="noopener">
          Reservar Vacante
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
        <a href="https://wa.me/51995955412" class="cta-btn-secondary" target="_blank" rel="noopener noreferrer">
          Contactar por WhatsApp
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .precal-cta {
    position: relative;
    background-color: var(--primary-blue);
    padding: 80px 40px;
    overflow: hidden;
  }

  .cta-bg-pattern {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(45deg, rgba(255, 255, 255, 0.03) 25%, transparent 25%),
      linear-gradient(-45deg, rgba(255, 255, 255, 0.03) 25%, transparent 25%),
      linear-gradient(45deg, transparent 75%, rgba(255, 255, 255, 0.03) 75%),
      linear-gradient(-45deg, transparent 75%, rgba(255, 255, 255, 0.03) 75%);
    background-size: 60px 60px;
    background-position: 0 0, 0 30px, 30px -30px, -30px 0px;
    pointer-events: none;
  }

  .cta-container {
    position: relative;
    z-index: 1;
    display: flex;
    justify-content: center;
  }

  .cta-content {
    text-align: center;
    max-width: 560px;
  }

  .cta-isotipo {
    width: 56px;
    height: 56px;
    margin: 0 auto 24px;
    opacity: 0.75;
  }

  .cta-title {
    font-family: var(--font-heading);
    font-size: clamp(36px, 5vw, 56px);
    line-height: 0.95;
    text-transform: uppercase;
    color: var(--text-primary);
    font-weight: 400;
    margin-bottom: 16px;
  }

  .cta-accent {
    color: var(--accent-gold);
  }

  .cta-motto {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    margin-bottom: 24px;
  }

  .motto-word {
    font-family: var(--font-heading);
    font-size: 20px;
    color: rgba(255, 255, 255, 0.9);
    text-transform: uppercase;
    letter-spacing: 2px;
  }

  .motto-separator {
    color: var(--accent-gold);
    font-weight: 700;
    font-size: 18px;
  }

  .cta-desc {
    font-family: var(--font-body);
    font-size: 15px;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.8);
    margin-bottom: 36px;
  }

  .cta-actions {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    flex-wrap: wrap;
  }

  .cta-btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 16px 32px;
    background-color: var(--bg-dark);
    color: var(--text-primary);
    font-family: var(--font-header);
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    transition: var(--transition);
    text-decoration: none;
  }

  .cta-btn-primary:hover {
    background-color: var(--white);
    color: var(--bg-dark);
  }

  .cta-btn-primary:hover svg {
    transform: translateX(4px);
  }

  .cta-btn-primary svg {
    transition: transform 0.3s ease;
  }

  .cta-btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 16px 32px;
    background-color: transparent;
    color: var(--text-primary);
    font-family: var(--font-header);
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    border: 2px solid rgba(255, 255, 255, 0.4);
    transition: var(--transition);
    text-decoration: none;
  }

  .cta-btn-secondary:hover {
    background-color: var(--white);
    color: var(--bg-dark);
    border-color: var(--white);
  }

  @media (max-width: 768px) {
    .precal-cta {
      padding: 56px 20px;
    }

    .cta-actions {
      flex-direction: column;
    }

    .cta-btn-primary,
    .cta-btn-secondary {
      width: 100%;
      justify-content: center;
    }

    .cta-motto {
      gap: 8px;
    }

    .motto-word {
      font-size: 16px;
    }
  }
</style>
