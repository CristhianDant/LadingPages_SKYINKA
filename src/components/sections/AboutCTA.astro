---
---

<section class="about-cta">
  <div class="cta-bg-pattern" aria-hidden="true"></div>
  <div class="cta-container container">
    <div class="cta-content">
      <img src="/images/isotipo-skip.svg" alt="" class="cta-isotipo" aria-hidden="true" />
      <h2 class="cta-title">
        ¿Listo para dar<br />
        <span class="cta-accent">el primer salto?</span>
      </h2>
      <p class="cta-desc">
        Forma parte de la comunidad aerodeportiva más profesional del Perú. Ya sea como paracaidista, alumno o aliado corporativo, te esperamos en SKIP.
      </p>
      <div class="cta-actions">
        <a href="/salto-tandem" class="cta-btn-primary">
          Salto Tándem
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
        <a href="https://wa.me/51999999999" class="cta-btn-secondary" target="_blank" rel="noopener noreferrer">
          Contactar ahora
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .about-cta {
    position: relative;
    background-color: var(--primary-blue);
    padding: 100px 0;
    overflow: hidden;
  }

  .cta-bg-pattern {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(45deg, rgba(255,255,255,0.03) 25%, transparent 25%),
      linear-gradient(-45deg, rgba(255,255,255,0.03) 25%, transparent 25%),
      linear-gradient(45deg, transparent 75%, rgba(255,255,255,0.03) 75%),
      linear-gradient(-45deg, transparent 75%, rgba(255,255,255,0.03) 75%);
    background-size: 60px 60px;
    background-position: 0 0, 0 30px, 30px -30px, -30px 0px;
    pointer-events: none;
  }

  .cta-container {
    position: relative;
    z-index: 1;
    max-width: var(--container-max-width);
    margin: 0 auto;
    padding: 0 var(--container-padding-x);
    display: flex;
    justify-content: center;
  }

  .cta-content {
    text-align: center;
    max-width: 640px;
  }

  .cta-isotipo {
    width: 64px;
    height: 64px;
    margin: 0 auto 28px;
    opacity: 0.8;
  }

  .cta-title {
    font-family: var(--font-heading);
    font-size: clamp(36px, 5vw, 64px);
    line-height: 1;
    text-transform: uppercase;
    color: var(--text-primary);
    font-weight: 400;
    margin-bottom: 24px;
  }

  .cta-accent {
    color: var(--accent-gold);
  }

  .cta-desc {
    font-family: var(--font-body);
    font-size: 16px;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.85);
    margin-bottom: 40px;
  }

  .cta-actions {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    flex-wrap: wrap;
  }

  .cta-btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 16px 32px;
    background-color: var(--bg-dark);
    color: var(--text-primary);
    font-family: var(--font-header);
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    transition: var(--transition);
  }

  .cta-btn-primary:hover {
    background-color: var(--white);
    color: var(--bg-dark);
  }

  .cta-btn-primary:hover svg {
    transform: translateX(4px);
  }

  .cta-btn-primary svg {
    transition: transform 0.3s ease;
  }

  .cta-btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 16px 32px;
    background-color: transparent;
    color: var(--text-primary);
    font-family: var(--font-header);
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    border: 2px solid rgba(255, 255, 255, 0.4);
    transition: var(--transition);
  }

  .cta-btn-secondary:hover {
    background-color: var(--white);
    color: var(--bg-dark);
    border-color: var(--white);
  }

  @media (max-width: 768px) {
    .about-cta {
      padding: 64px 0;
    }

    .cta-actions {
      flex-direction: column;
    }

    .cta-btn-primary,
    .cta-btn-secondary {
      width: 100%;
      justify-content: center;
    }
  }
</style>
