---
interface Props {
  name: string;
  role: string;
  description: string;
  badges: string[];
  gradientIndex: number;
  variant?: 'leadership' | 'team';
  memberNumber?: number;
}

const {
  name,
  role,
  description,
  badges,
  gradientIndex = 0,
  variant = 'team',
  memberNumber = gradientIndex + 1
} = Astro.props;

const initials = name.split(' ').map((w: string) => w[0]).join('').slice(0, 2).toUpperCase();
const truncatedDesc = description.length > 180 ? description.slice(0, 180) + '...' : description;
const showToggle = description.length > 180;

const gradients = [
  'linear-gradient(150deg, #0a0f2c 0%, #1a3a6b 35%, #4d7cea 100%)',
  'linear-gradient(150deg, #120c1e 0%, #2d1b4e 40%, #7b4dd3 100%)',
  'linear-gradient(150deg, #0a0f1a 0%, #1a3550 35%, #e07030 100%)',
  'linear-gradient(150deg, #0a0f2c 0%, #1c3a3a 35%, #20b2aa 100%)',
  'linear-gradient(150deg, #100a1e 0%, #3a1050 35%, #cc3366 100%)',
  'linear-gradient(150deg, #0a140f 0%, #1a4025 35%, #4eca7a 100%)',
  'linear-gradient(150deg, #0a0f2c 0%, #1b3b6f 35%, #ffd100 100%)',
  'linear-gradient(150deg, #14102a 0%, #2a1a4a 40%, #e94e77 100%)',
  'linear-gradient(150deg, #0a0f2c 0%, #2d1b69 35%, #7ad7ff 100%)',
  'linear-gradient(150deg, #1a0f14 0%, #4a1930 40%, #e94560 100%)',
  'linear-gradient(150deg, #0a0f2c 0%, #1a3550 35%, #f0a030 100%)',
  'linear-gradient(150deg, #0a0f2c 0%, #1a4a5a 35%, #4dceea 100%)',
];

const isLeadership = variant === 'leadership';
const idLabel = `SKIP-${String(memberNumber).padStart(3, '0')}`;
---

<div
  class={`staff-card ${isLeadership ? 'staff-card--leadership' : ''}`}
  x-data="{ expanded: false }"
  style={`animation-delay: ${gradientIndex * 0.07}s; --card-gradient: ${gradients[gradientIndex]}`}
>
  <div class="card-header">
    <span class="card-initials">{initials}</span>
    <span class="card-id">{idLabel}</span>
    <div class="card-scanline"></div>
    <div class="card-reticle"></div>
  </div>

  <div class="card-body">
    <h3 class="card-name">{name}</h3>
    <div class="card-rank-strip">
      <span class="rank-bar"></span>
      <p class="card-role">{role}</p>
    </div>

    <div class="card-badges">
      {badges.map((badge) => (
        <span class="card-badge">{badge}</span>
      ))}
    </div>

    <p class="card-desc">
      {truncatedDesc}
    </p>

    {showToggle && (
      <div x-show="expanded" x-collapse.duration.300ms>
        <p class="card-desc-full">{description}</p>
      </div>
    )}

    {showToggle && (
      <button class="card-toggle" @click="expanded = !expanded">
        <span class="toggle-text" x-text="expanded ? 'CLASIFICADO — OCULTAR' : 'EXPEDIENTE COMPLETO'"></span>
        <svg
          class="toggle-icon"
          :class="{ 'is-open': expanded }"
          width="10" height="6" viewBox="0 0 10 6" fill="none"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    )}
  </div>
</div>

<style>
  .staff-card {
    background-color: var(--white);
    border-left: 3px solid transparent;
    border-image: var(--card-gradient) 1;
    position: relative;
    overflow: hidden;
    transition: transform 0.4s cubic-bezier(0.22, 0.61, 0.36, 1), box-shadow 0.4s ease;
    opacity: 0;
    animation: cardSlideUp 0.7s cubic-bezier(0.22, 0.61, 0.36, 1) forwards;
  }

  @keyframes cardSlideUp {
    from { opacity: 0; transform: translateY(40px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .staff-card:hover {
    transform: translateY(-4px);
    box-shadow:
      0 12px 40px rgba(0, 0, 0, 0.08),
      0 0 0 1px rgba(77, 124, 234, 0.2);
  }

  /* ===== Header ===== */
  .card-header {
    position: relative;
    height: 160px;
    background: var(--card-gradient);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .staff-card--leadership .card-header {
    height: 200px;
  }

  .card-initials {
    font-family: var(--font-heading);
    font-size: 72px;
    color: rgba(255, 255, 255, 0.08);
    text-transform: uppercase;
    letter-spacing: 8px;
    transition: color 0.5s ease, transform 0.5s ease;
    z-index: 1;
  }

  .staff-card--leadership .card-initials {
    font-size: 96px;
    color: rgba(255, 255, 255, 0.06);
  }

  .staff-card:hover .card-initials {
    color: rgba(255, 255, 255, 0.18);
    transform: scale(1.08);
  }

  .card-id {
    position: absolute;
    top: 14px;
    right: 14px;
    font-family: var(--font-header);
    font-size: 9px;
    font-weight: 700;
    color: rgba(255, 255, 255, 0.5);
    letter-spacing: 2px;
    background: rgba(0, 0, 0, 0.3);
    padding: 4px 8px;
    border: 1px solid rgba(255, 255, 255, 0.15);
  }

  .card-scanline {
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(0, 0, 0, 0.03) 2px,
      rgba(0, 0, 0, 0.03) 4px
    );
    pointer-events: none;
  }

  .card-reticle {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 80px;
    height: 80px;
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 50%;
    pointer-events: none;
  }

  .card-reticle::before,
  .card-reticle::after {
    content: '';
    position: absolute;
    background: rgba(255, 255, 255, 0.04);
  }

  .card-reticle::before {
    top: -1px;
    left: 50%;
    transform: translateX(-50%);
    width: 2px;
    height: calc(100% + 2px);
  }

  .card-reticle::after {
    left: -1px;
    top: 50%;
    transform: translateY(-50%);
    height: 2px;
    width: calc(100% + 2px);
  }

  /* ===== Body ===== */
  .card-body {
    padding: 24px 28px 28px;
  }

  .card-name {
    font-family: var(--font-heading);
    font-size: 28px;
    color: var(--text-dark);
    text-transform: uppercase;
    line-height: 1;
    margin-bottom: 10px;
    font-weight: 400;
    letter-spacing: 1px;
  }

  .staff-card--leadership .card-name {
    font-size: 34px;
  }

  .card-rank-strip {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 16px;
  }

  .rank-bar {
    display: block;
    width: 20px;
    height: 2px;
    background: var(--primary-blue);
    flex-shrink: 0;
  }

  .staff-card--leadership .rank-bar {
    width: 32px;
    height: 3px;
  }

  .card-role {
    font-family: var(--font-header);
    font-size: 11px;
    font-weight: 700;
    color: var(--primary-blue);
    text-transform: uppercase;
    letter-spacing: 2px;
    line-height: 1.3;
  }

  .staff-card--leadership .card-role {
    font-size: 12px;
    letter-spacing: 2.5px;
  }

  .card-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 16px;
  }

  .card-badge {
    display: inline-flex;
    align-items: center;
    padding: 4px 10px;
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.6px;
    color: var(--gray-text);
    background: rgba(77, 124, 234, 0.06);
    border: 1px solid rgba(77, 124, 234, 0.15);
    transition: all 0.3s ease;
  }

  .staff-card:hover .card-badge {
    background: rgba(77, 124, 234, 0.14);
    border-color: rgba(77, 124, 234, 0.35);
    color: var(--primary-dark);
  }

  .card-desc {
    font-family: var(--font-body);
    font-size: 13px;
    line-height: 1.75;
    color: var(--gray-text);
    margin-bottom: 16px;
  }

  .card-desc-full {
    font-family: var(--font-body);
    font-size: 13px;
    line-height: 1.75;
    color: var(--gray-text);
    margin-bottom: 16px;
    padding-top: 4px;
    border-top: 1px solid rgba(0, 0, 0, 0.08);
  }

  /* ===== Toggle ===== */
  .card-toggle {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: none;
    border: none;
    font-family: var(--font-header);
    font-size: 10px;
    font-weight: 700;
    color: var(--primary-blue);
    text-transform: uppercase;
    letter-spacing: 1.5px;
    cursor: pointer;
    padding: 0;
    transition: all 0.3s ease;
  }

  .card-toggle:hover {
    color: var(--primary-dark);
    gap: 12px;
  }

  .toggle-icon {
    transition: transform 0.35s cubic-bezier(0.22, 0.61, 0.36, 1);
    flex-shrink: 0;
  }

  .toggle-icon.is-open {
    transform: rotate(180deg);
  }

  /* ===== Responsive ===== */
  @media (max-width: 768px) {
    .card-header {
      height: 120px;
    }

    .staff-card--leadership .card-header {
      height: 140px;
    }

    .card-initials {
      font-size: 52px;
      letter-spacing: 4px;
    }

    .staff-card--leadership .card-initials {
      font-size: 64px;
    }

    .card-body {
      padding: 20px;
    }

    .card-name {
      font-size: 24px;
    }

    .staff-card--leadership .card-name {
      font-size: 28px;
    }

    .card-reticle {
      width: 50px;
      height: 50px;
    }
  }
</style>
