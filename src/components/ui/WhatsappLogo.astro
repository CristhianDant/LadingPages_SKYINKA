---
interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
---

<a
  href="#"
  class:list={['whatsapp-float', className]}
  aria-label="Contactar por WhatsApp"
  target="_blank"
  rel="noopener noreferrer"
>
  <img
    src="/images/logo-skip-whatsapp.svg"
    alt="SKIP"
    width="80"
    height="80"
    loading="eager"
  />
</a>

<style>
  .whatsapp-float {
    position: fixed;
    bottom: 24px;
    right: 24px;
    z-index: 999;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 80px;
    height: 80px;
    background-color: transparent;
    cursor: pointer;
    transition: transform 0.3s ease, filter 0.2s ease;
    filter: drop-shadow(0 4px 12px rgba(77, 124, 234, 0.4));
  }

  .whatsapp-float:hover {
    transform: scale(1.1);
    filter: drop-shadow(0 6px 20px rgba(77, 124, 234, 0.5));
  }

  .whatsapp-float img {
    width: 100%;
    height: 100%;
  }
</style>
