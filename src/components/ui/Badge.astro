---
interface Props {
  variant?: 'default' | 'blue' | 'pink' | 'gold';
  class?: string;
}

const {
  variant = 'default',
  class: className = '',
  ...rest
} = Astro.props;
---

<span class:list={['badge', `badge-${variant}`, className]} {...rest}>
  <slot />
</span>

<style>
  .badge {
    display: inline-flex;
    align-items: center;
    padding: 4px 12px;
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    border-radius: var(--border-radius);
  }

  .badge-default {
    background-color: var(--bg-celeste);
    color: var(--gray-dark);
  }

  .badge-blue {
    background-color: var(--primary-blue);
    color: var(--text-primary);
  }

  .badge-pink {
    background-color: var(--pink-accent);
    color: var(--text-primary);
  }

  .badge-gold {
    background-color: var(--accent-gold);
    color: var(--text-dark);
  }
</style>
