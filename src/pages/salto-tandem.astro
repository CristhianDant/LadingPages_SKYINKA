---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/sections/Header.astro';
import TandemHeroSplit from '../components/sections/TandemHeroSplit.astro';
import TandemExperience from '../components/sections/TandemExperience.astro';
import TandemRequirements from '../components/sections/TandemRequirements.astro';
import TandemIncludes from '../components/sections/TandemIncludes.astro';
import TandemPricing from '../components/sections/TandemPricing.astro';
import TandemTerms from '../components/sections/TandemTerms.astro';
import TandemLocations from '../components/sections/TandemLocations.astro';
import BMICalculator from '../components/interactive/BMICalculator.astro';
import FAQAccordion from '../components/interactive/FAQAccordion.astro';
import TandemCTA from '../components/sections/TandemCTA.astro';
import Footer from '../components/sections/Footer.astro';
import MenuOverlay from '../components/interactive/MenuOverlay.astro';
import WhatsappLogo from '../components/ui/WhatsappLogo.astro';
---

<BaseLayout
  title="Salto Tándem Safiro - Skydive Inka Perú"
  description="Vive la experiencia de salto tándem en Paracas, Perú. Salto desde 9,000 pies con instructor certificado. S/. 1,970 + IGV. Reserva ahora."
>
  <Header />
  <MenuOverlay />
  <main>
    <TandemHeroSplit />
    <TandemExperience />
    <TandemRequirements />
    <TandemIncludes />
    <TandemPricing />
    <BMICalculator />
    <TandemTerms />
    <TandemLocations />
    <FAQAccordion />
    <TandemCTA />
  </main>
  <Footer />
  <WhatsappLogo />
</BaseLayout>
